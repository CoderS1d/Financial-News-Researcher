# Ollama runs locally — no API key needed.
# Install: https://ollama.com  |  then run: ollama pull qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# NewsAPI (optional — free key at https://newsapi.org, increases article coverage)
NEWSAPI_KEY=your_newsapi_key_here

OUTPUT_DIR=./output
